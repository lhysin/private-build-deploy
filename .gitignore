# ========================================================================
# UNIVERSAL GLOBAL .gitignore
# Java, Spring Boot, MSA, Node, Docker, K8s, macOS, IDEs, Infra
# Safe for Monorepo / Framework / Enterprise Projects
# ========================================================================


# ========================================================================
# 1. Operating System
# ========================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ========================================================================
# 2. Java & JVM
# ========================================================================
*.class
*.log
*.ctxt
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
*.exec
hs_err_pid*
replay_pid*
spring.log


# ========================================================================
# 3. Build Tools (Gradle / Maven)
# ========================================================================
target/
build/
.gradle/
.gradle-cache/
out/
bin/

# Gradle wrapper (keep wrapper, ignore caches)
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Maven wrapper (optional policy)
.mvn/wrapper/maven-wrapper.jar


# ========================================================================
# 4. Test & Coverage
# ========================================================================
jacoco.exec
coverage/
test-output/
surefire-reports/
failsafe-reports/


